# ── Vercel Postgres (auto-filled when you add the Postgres storage add-on) ──
POSTGRES_URL=postgresql://...   # filled by Vercel

# ── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-in-production

# ── CORS ─────────────────────────────────────────────────────────────────────
# Your frontend Vercel URL, e.g. https://knowledge-platform.vercel.app
CORS_ORIGINS=["https://your-frontend.vercel.app"]
